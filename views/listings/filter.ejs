<% layout("/layouts/boilerplate.ejs") %>   
<% if (filterListing.length) { %> 
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1 mt-3">
    <% for(let listing of filterListing) { %> 
        <div class="card col listing-card"  > 
            <a href="/listings/<%= listing._id %>">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"  style="height: 20rem;"> 
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %> </b><br>
                        &#8377;<%= listing.price.toLocaleString("en-IN")  %> /night
                    </p>
                </div>
            </a>
        </div> 
    <% } %>
</div>
<% } else { %>
      <div class="row mt-3 mb-3 ">
        <div class="alert alert-danger alert-dismissible fade show " role="alert"> 
            <h6>Listing is not added yet</h6>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
    <a href="<%= API_URL %>/listings" class="btn btn-primary " role="button" >Go back to home page</a>
<% } %>

 

 
 
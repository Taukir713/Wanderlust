<% layout("/layouts/boilerplate.ejs") %>  
<script src="/js/category.js"></script> 
 
<div class="filters">  
    <div class="filter-card">

        <div>
            <i class="fa-solid fa-angle-left"></i>
        </div> 
        
        <div class="filter " style="margin-left: 1rem; ">
            <a href="http://localhost:8080/listings/filter?category=Trending"   >
                <div> <i class="fa-solid fa-fire"></i> </div> 
                <p>Trending</p>
            </a>  
        </div> 
        
        <div class="filter">
            <a href="<%= API_URL %>/filter?category=Farms" onclick="filterCategory('')" >
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </a>
        </div> 
         
        <div class="filter" >
            <a href="<%= API_URL %>/filter?category=Iconic cities" onclick="filterCategory('')">
                <div value="Iconic cities"> <i class="fa-solid fa-mountain-city"></i> </div>
                    <p>Iconic cities</p>
            </a>
        </div> 

        <div class="filter"> 
            <a href="<%= API_URL %>/filter?category=Rooms" onclick="filterCategory('')" >
                <div>  <i class="fa-solid fa-couch"></i> </div> 
                <p>Rooms</p> 
            </a>
        </div>
        
        <div class="filter">
            <a href="<%= API_URL %>/filter?category=Castles" onclick="filterCategory('')" >
                <div>
                    <i class="fa-brands fa-fort-awesome"></i></i>
                </div>
                <p>Castles</p>
            </a> 
        </div>

        <div class="filter">
            <a href="<%= API_URL %>/filter?category=beach" onclick="filterCategory('')" >
                <div><i class="fa-solid fa-umbrella-beach"></i></div>
                <p>beach</p> 
            </a>
        </div>

        <div class="filter">
            <a href="<%= API_URL %>/filter?category=Mountain" onclick="filterCategory('')" >
                <div>
                    <i class="fa-solid fa-mountain"></i>
                </div>
                <p>Mountain</p>
            </a>
        </div>

        <div class="filter">
            <a href="<%= API_URL %>/filter?category=Amazing pools" onclick="filterCategory('')" >
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing pools</p>
            </a>
        </div>

        <div class="filter">
            <a href="<%= API_URL %>/filter?category=camping" onclick="filterCategory('')" >
                <div><i class="fa-solid fa-campground"></i></div>
                <p>camping</p>
            </a>
        </div>

        <div class="filter">
            <a href="<%= API_URL %>/filter?category=Arctic" onclick="filterCategory('')" >
                <div><i class="fa-solid fa-snowman"></i></div>
                <p>Arctic</p>
            </a>
        </div> 

        <div>
            <i class="fa-solid fa-angle-right"></i>
        </div>

    </div> 

    <div class="switch-container mb-2">
        <div class="form-check form-switch form-check-reverse">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Diplay total after taxes</label>
        </div>
    </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2  row-cols-sm-1 row-cols-1 listing-container">
    <% for(let listing of allListings) { %> 
        <div class="card col listing-card"  > 
            <a href="/listings/<%= listing._id %>">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"  style="height: 20rem;"> 
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %> </b><br>
                        &#8377;<%= listing.price.toLocaleString("en-IN")  %> /night
                        <i class="tax-info">&nbsp; &nbsp; &nbsp; +18% GST</i>
                    </p>
                </div>
            </a>
        </div> 
    <% } %>
</div>

 
<script src="/js/toggleSwitch.js"></script>
 
 